FABRIC_TENANT_ID=<tenant-id>
FABRIC_SQL_SERVER=<fabric-sql-endpoint-host>
FABRIC_SQL_DATABASE=<database-or-catalog-name>
FABRIC_WORKSPACE_ID=<workspace-id>
FABRIC_SQL_ENDPOINT_ID=<sql-endpoint-item-id>
MCP_ENDPOINT=http://localhost:8000/mcp
MCP_AUTH_TOKEN=<strong-random-token>
MCP_ALLOWED_ORIGINS=https://your-chat-app.example.com
MCP_RATE_LIMIT_PER_MINUTE=60
FABRIC_SQL_MAX_QUERY_ROWS=5000
FABRIC_SQL_MAX_EXPORT_ROWS=100000
FABRIC_SQL_MAX_EXPORT_PAGE_SIZE=5000
FABRIC_SQL_EXPORT_DIR=/tmp/fabric-sql-mcp-exports
